{
  "name": "grimmore",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "protocol:generate": "pnpm --filter @grimmore/protocol generate",
    "test": "pnpm -r test && pnpm test:release-slice",
    "test:release-slice": "node --test tests/release/slice-install-rollback.mjs",
    "test:release-macos": "bash tests/release/macos-signed-install-rollback.sh",
    "test:release-windows": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File tests/release/windows-signed-install-rollback.ps1",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
